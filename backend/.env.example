DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/parakeet_wellness
SECRET_KEY=replace-with-a-very-long-random-secret-32-plus-chars
DEBUG=true
DB_AUTO_CREATE_ON_STARTUP=true
ENFORCE_ALEMBIC_HEAD=false
STORAGE_BACKEND=local
UPLOAD_DIR=/app/uploads
CORS_ORIGINS=http://localhost:19006,http://127.0.0.1:19006,http://localhost:3000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_URL=redis://redis:6379/0
RATE_LIMIT_KEY_PREFIX=rate-limit
RATE_LIMIT_REDIS_STRICT=false
GUEST_SECRET_MIN_LENGTH=24
FEATURE_CONTEXT_ENGINE=true
FEATURE_CAPTURE_QUALITY=true
FEATURE_IOS_UX_FOUNDATION=true
FEATURE_ADVANCED_REASONING=false
FEATURE_OFFLINE_RESILIENCE=false
FEATURE_SMART_DISCOVERY=false
# Audio processing
AUDIO_SAMPLE_RATE=22050
AUDIO_MIN_DURATION_SECONDS=2.0
AUDIO_MAX_DURATION_SECONDS=300
AUDIO_SEGMENT_DURATION=3.0

# Context providers
AIRNOW_API_KEY=
CONTEXT_HTTP_TIMEOUT_SECONDS=8
CONTEXT_AUTO_REFRESH_ENABLED=false
CONTEXT_REFRESH_INTERVAL_SECONDS=1800
